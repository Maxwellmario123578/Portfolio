{
  "routes": [
    {
      "src": "/Cahier_projets/(.*)",
      "headers": {
        "Content-Type": "application/pdf",
        "Content-Disposition": "attachment"
      },
      "dest": "/Cahier_projets/$1"
    },
    {
      "src": "/(.*\\.(pdf|png|jpg|jpeg|svg|ico|txt|xml|gif|webp))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
